    skos:prefLabel "Event"@en,
        "사건"@ko .

ggc:material_culture a skos:Concept ;
    skos:inScheme ggc:scheme ;
    skos:prefLabel "Material Culture"@en,
        "물질문화"@ko ;
    skos:scopeNote "유물·복식·공예"@ko .

ggc:genre a skos:Concept ;
    skos:inScheme ggc:scheme ;
    skos:prefLabel "Genre"@en,
        "장르·형식"@ko .

ggc:place a skos:Concept ;
    skos:inScheme ggc:scheme ;
    skos:prefLabel "Place"@en,
        "장소"@ko .

ggc:gwanje a skos:Concept ;
    owl:sameAs <http://www.wikidata.org/entity/Q10948283> ;
    skos:broader ggc:institution ;
    skos:inScheme ggc:scheme ;
    skos:prefLabel "Government system"@en,
        "관제·정치제도"@ko ;
    skos:scopeNote "고려 관직·정치제도 일반"@ko .

ggc:institution a skos:Concept ;
    skos:inScheme ggc:scheme ;
    skos:prefLabel "Institution"@en,
        "제도"@ko ;
    skos:scopeNote "정치·사회 제도"@ko .

ggc:work a skos:Concept ;
    skos:inScheme ggc:scheme ;
    skos:prefLabel "Work"@en,
        "문헌"@ko ;
    skos:scopeNote "저작·1차 사료"@ko .

ggc:scholarship a skos:Concept ;
    skos:inScheme ggc:scheme ;
    skos:prefLabel "Scholarship"@en,
        "학술 분야"@ko .

ggc:person a skos:Concept ;
    skos:inScheme ggc:scheme ;
    skos:prefLabel "Person"@en,
        "인물"@ko .

ggc:scheme a skos:ConceptScheme ;
    skos:hasTopConcept ggc:event,
        ggc:genre,
        ggc:institution,
        ggc:material_culture,
        ggc:period,
        ggc:person,
        ggc:place,
        ggc:scholarship,
        ggc:work ;
    skos:prefLabel "강감찬자료실 주제어휘 초안"@ko .

