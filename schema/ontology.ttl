    schema:latitude 37.4841833 ; schema:longitude 126.9497246 .

# --- 원천 목록 인스턴스 --------------------------------------
ggo:list-books a schema:Collection ;
    schema:name "강감찬자료실 도서목록"@ko ;
    schema:url <https://lib.gwanak.go.kr/galib/menu/10071/program/30018/referenceBookList.do> .
