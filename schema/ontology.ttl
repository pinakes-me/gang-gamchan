@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix schema:  <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix ggo:     <https://pinakes-me.github.io/gang-gamchan/ontology#> .

##############################################################
# 강감찬자료실 LOD 파일럿 — 데이터 모델 스케치 v0.1
#
# 설계 원칙
# 1. 바퀴를 재발명하지 않는다: 서지는 schema.org + DC Terms,
#    주제어는 SKOS, 외부 연결은 owl:sameAs → Wikidata.
# 2. 커스텀 어휘(ggo:)는 표준으로 표현 못 하는 것만 최소한으로.
# 3. 도서관 목록은 그래프의 "뼈대"가 아니라, Wikidata 등
#    외부 지식그래프의 노드에 매달리는 "지역의 살"이다.
##############################################################

ggo: a owl:Ontology ;
    rdfs:label "강감찬자료실 LOD 파일럿 온톨로지"@ko ;
    dcterms:creator "Hailey (@pinakes_me)" .

# --- 클래스 -------------------------------------------------
# 자료:      schema:Book / schema:ScholarlyArticle / schema:VideoObject
# 주제어:    skos:Concept  (vocab/concepts.csv 에서 생성)
# 도서관:    schema:Library (위치 좌표 포함 → 자전거 접근성 데이터와 연결점)
# 장소:      schema:Place   (낙성대 등, 지도 레이어용)

# --- 커스텀 속성 (최소한) ------------------------------------
ggo:heldBy a owl:ObjectProperty ;
    rdfs:label "소장처"@ko ;
    rdfs:comment "관악구통합도서관 내 소장 분관. 목록의 '소장도서관' 컬럼. 이 속성이 국중도·Wikidata에는 없는 이 데이터셋 고유의 가치."@ko ;
    rdfs:domain schema:CreativeWork ;
    rdfs:range  schema:Library .

ggo:sourceList a owl:ObjectProperty ;
    rdfs:label "출처 목록"@ko ;
    rdfs:comment "자료가 등재된 원천 큐레이션 목록(도서목록/논문목록/미디어목록)"@ko .

# --- 소장도서관 인스턴스 (좌표는 추후 자전거 프로젝트 데이터에서) ---
ggo:lib-gwanak-central a schema:Library ;
    schema:name "관악중앙도서관"@ko .
ggo:lib-yongkkum a schema:Library ;
    schema:name "용꿈꾸는작은도서관"@ko ;
    rdfs:comment "관악구청 내 — 관악구 동주민센터 작은도서관 현황 근거"@ko ;
    schema:latitude 37.4786026 ; schema:longitude 126.9517566 .
ggo:lib-chaeksarang a schema:Library ;
    schema:name "책사랑작은도서관"@ko ;
    rdfs:comment "난곡동주민센터 3층 — 관악구 동주민센터 작은도서관 현황 근거"@ko ;
    schema:latitude 37.4708819 ; schema:longitude 126.9216452 .
ggo:lib-tteuran a schema:Library ;
    schema:name "뜰안에작은도서관"@ko ;
    schema:latitude 37.461481 ; schema:longitude 126.918785 .
ggo:lib-seonghyeon a schema:Library ;
    schema:name "성현동작은도서관"@ko ;
    schema:latitude 37.4872411 ; schema:longitude 126.9561249 .
