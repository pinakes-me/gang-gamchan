    schema:name "보물섬작은도서관"@ko ;
    rdfs:comment "인헌동 소재 — '인헌(仁憲)'은 강감찬의 시호"@ko ;
    schema:latitude 37.4751167 ; schema:longitude 126.965293 .
ggo:lib-nakseongdae-park a schema:Library ;
    schema:name "낙성대공원도서관"@ko ;
    rdfs:comment "낙성대공원 안에 위치 — 강감찬 탄생 전승지의 도서관"@ko ;
    schema:latitude 37.4711594 ; schema:longitude 126.9601859 .
ggo:lib-jowon a schema:Library ;
